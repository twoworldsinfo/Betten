<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Betten-Planer Costa Azul 208</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-gray-100 min-h-screen flex items-center justify-center p-6">

    <div class="max-w-4xl w-full bg-gray-800 rounded-2xl shadow-2xl p-8 border border-gray-700">
        <h1 class="text-3xl font-extrabold text-center text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500 mb-2">
            Betten-Auswahl für Penthouse 208
        </h1>
        <p class="text-gray-400 text-center mb-8">Wählen Sie die Größe und vergleichen Sie unsere 3 Premium-Optionen mit Stauraum.</p>

        <!-- Size Toggle -->
        <div class="flex justify-center mb-8">
            <div class="bg-gray-950 p-1 rounded-xl flex border border-gray-700">
                <button onclick="setSize('queen')" id="btn-queen" class="px-6 py-2 rounded-lg font-bold text-gray-400 transition-all duration-200 hover:text-white">
                    Queen Size (158x198 cm)
                </button>
                <button onclick="setSize('king')" id="btn-king" class="px-6 py-2 rounded-lg font-bold transition-all duration-200 bg-emerald-500 text-gray-950">
                    King Size (193x203 cm)
                </button>
            </div>
        </div>

        <!-- Cards Container -->
        <div class="grid md:grid-cols-3 gap-6 mb-8">
            <!-- Option 1 -->
            <div onclick="selectOption(1)" id="card-1" class="cursor-pointer bg-gray-900 border-2 border-transparent rounded-xl p-6 transition-all hover:border-emerald-500/50 flex flex-col justify-between">
                <div>
                    <!-- Image Slot Ortobom -->
                    <div class="w-full h-48 bg-gray-850 rounded-lg overflow-hidden mb-4 border border-gray-750 flex items-center justify-center" style="height: 12rem; width: 100%; overflow: hidden;">
                        <img src="http://googleusercontent.com/image_collection/image_retrieval/8120861882664844018_0" id="img-opt-1" alt="Ortobom Bett" class="w-full h-full object-cover" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Option 1</span>
                    <h3 class="text-xl font-bold mt-1">Ortobom Leinen-Kombi</h3>
                    <p class="text-xs text-gray-400 mb-4">Gutes Preis-Leistungs-Verhältnis</p>
                    <ul class="text-sm text-gray-400 space-y-2 mb-6">
                        <li>Hochwertiger Leinen-Bezug im edlen Design.</li>
                        <li>Geteilte Box (Bipartido) für leichteren Transport.</li>
                        <li>Inklusive Novo Ouro Spring Matratze.</li>
                    </ul>
                </div>
                <div>
                    <div id="price-1" class="text-2xl font-black text-white font-mono">R$ 7.828</div>
                    <div id="price-eur-1" class="text-xs text-gray-500 mb-4 font-mono">~1.305 €</div>
                    <div id="select-btn-1" class="w-full text-center py-2 bg-gray-800 rounded-lg text-sm font-semibold border border-gray-700">Auswählen</div>
                </div>
            </div>

            <!-- Option 2 (Favorit) -->
            <div onclick="selectOption(2)" id="card-2" class="cursor-pointer bg-gray-900 border-2 border-transparent rounded-xl p-6 transition-all hover:border-emerald-500/50 flex flex-col justify-between">
                <div>
                    <!-- Image Slot Emma -->
                    <div class="w-full h-48 bg-gray-850 rounded-lg overflow-hidden mb-4 border border-gray-750 flex items-center justify-center" style="height: 12rem; width: 100%; overflow: hidden;">
                        <img src="https://eu-images.contentstack.com/v3/assets/blt167b24547e5b1906/blt1198d96255b61b88/69ca5b92810b4fbf48006911/BR_Kit-Perso_Cama-Bau_Hybrid-II_King_EASTER-26.png?format=auto&quality=80&width=1280&disable=upscale&crop=16:9" id="img-opt-2" alt="Emma Bett" class="w-full h-full object-cover" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest">Option 2 (Favorit)</span>
                    <h3 class="text-xl font-bold mt-1">Emma Premium Set</h3>
                    <p class="text-xs text-emerald-400 mb-4">Unsere Empfehlung</p>
                    <ul class="text-sm text-gray-400 space-y-2 mb-6">
                        <li>Hybrid-Matratze und integrierter Stauraum-Bettkasten.</li>
                        <li>Einfacher Transport: Wird komplett gerollt im Karton geliefert.</li>
                        <li>Globale Marke, die internationale Gäste sofort wiedererkennen.</li>
                    </ul>
                </div>
                <div>
                    <div id="price-2" class="text-2xl font-black text-white font-mono">R$ 9.882</div>
                    <div id="price-eur-2" class="text-xs text-gray-500 mb-4 font-mono">~1.647 €</div>
                    <div id="select-btn-2" class="w-full text-center py-2 bg-gray-800 rounded-lg text-sm font-semibold border border-gray-700">Auswählen</div>
                </div>
            </div>

            <!-- Option 3 -->
            <div onclick="selectOption(3)" id="card-3" class="cursor-pointer bg-gray-900 border-2 border-transparent rounded-xl p-6 transition-all hover:border-emerald-500/50 flex flex-col justify-between">
                <div>
                    <!-- Image Slot Simmons -->
                    <div class="w-full h-48 bg-gray-850 rounded-lg overflow-hidden mb-4 border border-gray-750 flex items-center justify-center" style="height: 12rem; width: 100%; overflow: hidden;">
                        <img src="http://googleusercontent.com/image_collection/image_retrieval/5511144166295703176_0" id="img-opt-3" alt="Simmons Bett" class="w-full h-full object-cover" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Option 3</span>
                    <h3 class="text-xl font-bold mt-1">Simmons Luxury Set</h3>
                    <p class="text-xs text-purple-400 mb-4">5-Sterne Luxus</p>
                    <ul class="text-sm text-gray-400 space-y-2 mb-6">
                        <li>Hotel-Standard für exzellentes Schlaferlebnis.</li>
                        <li>Sehr schweres Material.</li>
                        <li>Lieferung erfordert eventuell ein Seil-Hebesystem.</li>
                    </ul>
                </div>
                <div>
                    <div id="price-3" class="text-2xl font-black text-white font-mono">R$ 17.910</div>
                    <div id="price-eur-3" class="text-xs text-gray-500 mb-4 font-mono">~2.985 €</div>
                    <div id="select-btn-3" class="w-full text-center py-2 bg-gray-800 rounded-lg text-sm font-semibold border border-gray-700">Auswählen</div>
                </div>
            </div>
        </div>

        <!-- Copy Action Button -->
        <button onclick="submitSelection()" class="w-full py-4 bg-gradient-to-r from-emerald-500 to-teal-500 text-gray-950 font-black text-lg rounded-xl shadow-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
            <span>Auswahl absenden</span>
        </button>
    </div>

    <script>
        var selectedSize = 'king';
        var selectedOptionId = null;

        var MY_PHONE_NUMBER = "5521990486565"; 

        var data = {
            queen: {
                1: { brl: "R$ 6.568,00", eur: "~1.095 €", name: "Option 1 (Ortobom Leinen-Kombi - Queen)" },
                2: { brl: "R$ 7.900,00", eur: "~1.316 €", name: "Option 2 (Emma Premium Hybrid Set - Queen)" },
                3: { brl: "R$ 14.500,00", eur: "~2.416 €", name: "Option 3 (Simmons Times Square Set - Queen)" }
            },
            king: {
                1: { brl: "R$ 7.828,00", eur: "~1.305 €", name: "Option 1 (Ortobom Leinen-Kombi - King)" },
                2: { brl: "R$ 9.882,59", eur: "~1.647 €", name: "Option 2 (Emma Premium Hybrid Set - King)" },
                3: { brl: "R$ 17.910,00", eur: "~2.985 €", name: "Option 3 (Simmons Times Square Set - King)" }
            }
        };

        function setSize(size) {
            selectedSize = size;
            document.getElementById('btn-queen').className = size === 'queen' ? 'px-6 py-2 rounded-lg font-bold transition-all duration-200 bg-emerald-500 text-gray-950' : 'px-6 py-2 rounded-lg font-bold text-gray-400 transition-all duration-200 hover:text-white';
            document.getElementById('btn-king').className = size === 'king' ? 'px-6 py-2 rounded-lg font-bold transition-all duration-200 bg-emerald-500 text-gray-950' : 'px-6 py-2 rounded-lg font-bold text-gray-400 transition-all duration-200 hover:text-white';
            
            for (var i = 1; i <= 3; i++) {
                document.getElementById('price-' + i).innerText = data[size][i].brl.replace(',00', '');
                document.getElementById('price-eur-' + i).innerText = data[size][i].eur;
            }
            selectOption(selectedOptionId || 2);
        }

        function selectOption(id) {
            selectedOptionId = id;
            for (var i = 1; i <= 3; i++) {
                var card = document.getElementById('card-' + i);
                var btn = document.getElementById('select-btn-' + i);
                if (i === id) {
                    card.classList.add('border-emerald-500', 'bg-gray-800');
                    card.classList.remove('border-transparent', 'bg-gray-900');
                    btn.className = "w-full text-center py-2 bg-emerald-500 text-gray-950 rounded-lg text-sm font-bold";
                    btn.innerText = "Ausgewählt";
                } else {
                    card.classList.remove('border-emerald-500', 'bg-gray-800');
                    card.classList.add('border-transparent', 'bg-gray-900');
                    btn.className = "w-full text-center py-2 bg-gray-800 text-gray-400 rounded-lg text-sm font-semibold border border-gray-700";
                    btn.innerText = "Auswählen";
                }
            }
        }

        function submitSelection() {
            if (!selectedOptionId) selectOption(2);
            var selection = data[selectedSize][selectedOptionId];
            
            var messageText = 'Hi Florian, ich habe mich entschieden!\n\n' +
                'Groesse: ' + selectedSize.toUpperCase() + '\n' +
                'Gewaehltes Modell: ' + selection.name + '\n' +
                'Preis: ' + selection.brl + ' (' + selection.eur + ')\n\n' +
                'Bitte so auf die Einkaufsliste setzen!';
            
            var encodedText = encodeURIComponent(messageText);
            
            window.location.href = 'https://wa.me/' + MY_PHONE_NUMBER + '?text=' + encodedText;
        }

        // Init with King Size and Emma (Option 2) pre-selected
        setSize('king');
        selectOption(2);
    </script>
</body>
</html>
